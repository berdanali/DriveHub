# ============================================
# PRODUCTION ENVIRONMENT VARIABLES
# ============================================
# Bu dosyayı sunucuda .env olarak kopyalayıp gerçek değerlerle doldurun
# cp env.production.example .env

# ---- Domain ----
DOMAIN=senindomain.com

# ---- Database ----
DB_USER=car_rental_user
DB_PASSWORD=BURAYA_GUCLU_SIFRE_YAZ
DB_NAME=car_rental_prod

# ---- Redis ----
REDIS_PASSWORD=BURAYA_REDIS_SIFRESI_YAZ

# ---- JWT (güçlü rastgele stringler kullan) ----
# Oluşturmak için: openssl rand -base64 64
JWT_ACCESS_SECRET=BURAYA_RASTGELE_ACCESS_SECRET
JWT_REFRESH_SECRET=BURAYA_RASTGELE_REFRESH_SECRET

# ---- CORS ----
CORS_ORIGIN=https://senindomain.com

# ---- Frontend API URL ----
VITE_API_URL=https://senindomain.com/api

# ---- Mail (Gmail SMTP) ----
MAIL_USER=senin@gmail.com
MAIL_PASS=uygulama_sifresi

# ---- Commission ----
COMMISSION_RATE=0.15

